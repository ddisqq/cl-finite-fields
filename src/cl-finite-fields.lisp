;;; ============================================================================
;;; Standard Toolkit for cl-finite-fields
;;; ============================================================================

(defmacro with-finite-fields-timing (&body body)
  "Executes BODY and logs the execution time specific to cl-finite-fields."
  (let ((start (gensym))
        (end (gensym)))
    `(let ((,start (get-internal-real-time)))
       (multiple-value-prog1
           (progn ,@body)
         (let ((,end (get-internal-real-time)))
           (format t "~&[cl-finite-fields] Execution time: ~A ms~%"
                   (/ (* (- ,end ,start) 1000.0) internal-time-units-per-second)))))))

(defun finite-fields-batch-process (items processor-fn)
  "Applies PROCESSOR-FN to each item in ITEMS, handling errors resiliently.
Returns (values processed-results error-alist)."
  (let ((results nil)
        (errors nil))
    (dolist (item items)
      (handler-case
          (push (funcall processor-fn item) results)
        (error (e)
          (push (cons item e) errors))))
    (values (nreverse results) (nreverse errors))))

(defun finite-fields-health-check ()
  "Performs a basic health check for the cl-finite-fields module."
  (let ((ctx (initialize-finite-fields)))
    (if (validate-finite-fields ctx)
        :healthy
        :degraded)))
